{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist-server",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "baseUrl": "./src"
  },
  "include": ["src/server/**/*", "src/types.ts"],
  "exclude": ["node_modules", "dist", "dist-server", "src/components", "src/hooks", "src/context"]
}
