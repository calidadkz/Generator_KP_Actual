# GEMINI_API_KEY: Required for Gemini AI API calls (Backend Node.js server only).
# For local development: set here.
# For Cloud Run: provided via --set-secrets=GEMINI_API_KEY=GEMINI_API_KEY:latest
# The backend (src/server/index.ts) reads this at runtime from process.env.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
